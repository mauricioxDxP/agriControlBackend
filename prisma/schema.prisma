generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProductType {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
  plantedProductTypes PlantedProductType[]
}

model ProductState {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model ContainerTypeModel {
  id          String   @id @default(uuid())
  name        String   @unique
  createdAt   DateTime @default(now())
  defaultUnit BaseUnit @default(L)
  lots        Lot[]
}

model Product {
  id                    String               @id @default(uuid())
  name                  String
  productCode           String?              // Código interno del producto
  typeId                String
  stateId               String
  baseUnit              BaseUnit
  dosePerHectareMin     Float?
  dosePerHectareMax     Float?
  concentration         Float?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  synced                Boolean             @default(false)
  concentrationPerLiter Float?
  doseType              DoseType?
  doseUnit              DoseUnit?
  genericName           String?
  applicationProducts   ApplicationProduct[]
  lots                  Lot[]
  movements             Movement[]
  state                 ProductState         @relation(fields: [stateId], references: [id])
  type                  ProductType          @relation(fields: [typeId], references: [id])
  tancadaProducts       TancadaProduct[]
  fieldProducts         Field[]              @relation("FieldProduct")
}

model Lot {
  id                String              @id @default(uuid())
  productId         String
  entryDate         DateTime            @default(now())
  expiryDate        DateTime?
  supplier          String?
  initialStock      Float
  containerTypeId   String?
  containerCapacity Float?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  synced            Boolean             @default(false)
  lotCode           String?
  applicationLots   ApplicationLot[]
  containerType     ContainerTypeModel? @relation(fields: [containerTypeId], references: [id])
  product           Product             @relation(fields: [productId], references: [id])
  movements         Movement[]
}

model Field {
  id            String         @id @default(uuid())
  name          String
  area          Float
  location      String?
  latitude      Float?
  longitude     Float?
  productId     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  synced        Boolean        @default(false)
  applications  Application[]
  tancadaFields TancadaField[]
  product       Product?       @relation("FieldProduct", fields: [productId], references: [id])
}

// Configuración global: tipos de producto que están "plantados" (se usan como filtro en campos)
model PlantedProductType {
  id            String      @id @default(uuid())
  productTypeId String
  productType   ProductType @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([productTypeId])
}

model Application {
  id                  String               @id @default(uuid())
  fieldId             String
  type                ApplicationType
  date                DateTime             @default(now())
  waterAmount         Float?
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  synced              Boolean              @default(false)
  field               Field                @relation(fields: [fieldId], references: [id])
  applicationLots     ApplicationLot[]
  applicationProducts ApplicationProduct[]
}

model ApplicationProduct {
  id                    String      @id @default(uuid())
  applicationId         String
  productId             String
  dosePerHectare        Float?
  concentration         Float?
  quantityUsed          Float
  lotsUsed              String?
  createdAt             DateTime    @default(now())
  synced                Boolean     @default(false)
  concentrationPerLiter Float?
  application           Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  product               Product     @relation(fields: [productId], references: [id])

  @@unique([applicationId, productId])
}

model Movement {
  id            String       @id @default(uuid())
  productId     String
  lotId         String?
  type          MovementType
  quantity      Float
  notes         String?
  tancadaId     String?
  applicationId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  synced        Boolean      @default(false)
  lot           Lot?         @relation(fields: [lotId], references: [id])
  product       Product      @relation(fields: [productId], references: [id])
}

model ApplicationLot {
  id            String      @id @default(uuid())
  applicationId String
  lotId         String
  quantityUsed  Float
  createdAt     DateTime    @default(now())
  synced        Boolean     @default(false)
  application   Application @relation(fields: [applicationId], references: [id])
  lot           Lot         @relation(fields: [lotId], references: [id])

  @@unique([applicationId, lotId])
}

model Tancada {
  id              String           @id @default(uuid())
  date            DateTime         @default(now())
  tankCapacity    Float
  waterAmount     Float
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  synced          Boolean          @default(false)
  tancadaFields   TancadaField[]
  tancadaProducts TancadaProduct[]
}

model TancadaProduct {
  id            String   @id @default(uuid())
  tancadaId     String
  productId     String
  concentration Float?
  quantity      Float
  lotsUsed      String?
  createdAt     DateTime @default(now())
  synced        Boolean  @default(false)
  product       Product  @relation(fields: [productId], references: [id])
  tancada       Tancada  @relation(fields: [tancadaId], references: [id], onDelete: Cascade)

  @@unique([tancadaId, productId])
}

model TancadaField {
  id              String   @id @default(uuid())
  tancadaId       String
  fieldId         String
  hectaresTreated Float
  productUsed     Float
  createdAt       DateTime @default(now())
  synced          Boolean  @default(false)
  field           Field    @relation(fields: [fieldId], references: [id])
  tancada         Tancada  @relation(fields: [tancadaId], references: [id])

  @@unique([tancadaId, fieldId])
}

model Tank {
  id        String   @id @default(uuid())
  name      String
  capacity  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  synced    Boolean  @default(false)
}

enum BaseUnit {
  KG
  G
  L
  ML
  CC
}

enum DoseUnit {
  BASE_UNIT
  CC
  ML
  G
  KG
  L
}

enum ApplicationType {
  FUMIGACION
  SIEMBRA
}

enum MovementType {
  ENTRADA
  SALIDA
}

enum DoseType {
  PER_HECTARE
  CONCENTRATION
}
